# Copy this file to .env.local and fill in your keys. .env.local is gitignored.

# --- Congress.gov (Power ingestion) ---------------------------------------
# Free key, instant signup: https://api.congress.gov/sign-up/
# Used by: npm run ingest:power
CONGRESS_API_KEY=

# --- Supabase (data layer) -------------------------------------------------
# Create a project at https://supabase.com, run supabase/schema.sql in the SQL
# editor, then fill these from Project Settings -> API.
#
# When these two are set, the app reads live data instead of the seed:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# Service-role key — used ONLY by scripts (npm run db:seed) to upload data.
# Never expose this in the browser / client bundle.
SUPABASE_SERVICE_ROLE_KEY=
